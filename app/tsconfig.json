{
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"$db/*": ["./src/db/*"],
			"$validators/*": ["./src/validators/*"]
		},
		"target": "ESNext",
		"module": "NodeNext",
		"strict": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"types": ["node"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"outDir": "./dist"
	},
	"exclude": ["node_modules"]
}
